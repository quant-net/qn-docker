# Quant-Net Docker — Environment Overrides
#
# Copy this file to .env and uncomment/edit lines as needed.
#
# Usage:
#   cp .env.example .env
#   # Edit .env to set desired values
#   docker compose build --no-cache
#   docker compose up -d

# ── Container Image Tag ──────────────────────────────────────────────
# Override the ghcr.io image tag for all services.
# Default is "main" in docker-compose.yml, "develop" in docker-compose-dqc.yml.
# Examples: main, develop, v1.1.0, sha-abc1234
#
# IMAGE_TAG=develop

# ── PyPI Package Versions (build-time only) ──────────────────────────
# Pin specific PyPI package versions when building Docker images.
# Useful for testing release candidates (RCs) before a stable release.
# Values must include the pip version specifier (e.g., ==1.1.0rc1).
# Leave commented out to install the latest stable release.
#
# One-off override without .env:
#   QUANTNET_API_VERSION="==1.1.0rc2" docker compose build api
#
# QUANTNET_MQ_VERSION==1.0.0rc1
# QUANTNET_SERVER_VERSION==1.0.0rc1
# QUANTNET_AGENT_VERSION==1.0.0rc1
# QUANTNET_API_VERSION==1.0.0rc1
